# Client Side
BACKEND_PROXY=http://localhost:3000

# Client Side
VITE_ENV=development # development, staging, production

# API URL — base for the LMS backend
VITE_API_URL=http://localhost:3000/api/v1

# Tenant slug — must match a tenant.slug seeded in the LMS backend
VITE_TENANT_SLUG=albero-academy

# Dashboard URL — where the navbar "Sign in" button redirects. Point at
# wherever the LMS Frontend/ is served (dev: http://localhost:5174,
# prod: https://app.alberoacademy.in or similar).
VITE_DASHBOARD_URL=http://localhost:5174

# Server Side
PORT=5173

# Google Sheets (legacy contact form fallback — not used once backend is live)
VITE_SHEET_URL=your_google_sheet_script_url
