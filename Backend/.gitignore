# --- Environment files ---------------------------------------------------
# dotenv-flow loads in this order (later overrides earlier):
#   .env  →  .env.local  →  .env.<NODE_ENV>  →  .env.<NODE_ENV>.local
#
# Committed (safe, non-secret defaults):
#   .env.example          — template for contributors
#   .env.development      — local-dev defaults (non-secret)
#   .env.production       — production placeholders (no real secrets)
#
# Gitignored (real secrets live here):
#   .env                  — always
#   .env.local            — personal overrides
#   .env.*.local          — per-env secrets (e.g. .env.production.local)
.env
.env.local
.env.*.local
.env.development
.env.production
