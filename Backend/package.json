{
    "name": "learnhub-backend",
    "version": "1.0.0",
    "description": "LearnHub LMS Phase 1 backend — Express + Prisma + Postgres (Neon) + Redis",
    "main": "dist/server.js",
    "scripts": {
        "dist": "npx tsc",
        "build": "npx prisma generate && npx tsc",
        "dev": "cross-env NODE_ENV=development nodemon --legacy-watch src/server.ts",
        "dev:dev": "cross-env NODE_ENV=development nodemon --legacy-watch src/server.ts",
        "dev:prod": "cross-env NODE_ENV=production nodemon --legacy-watch src/server.ts",
        "start": "cross-env NODE_ENV=production node dist/server.js",
        "start:dev": "cross-env NODE_ENV=development node dist/server.js",
        "start:prod": "cross-env NODE_ENV=production node dist/server.js",
        "worker:dev": "cross-env NODE_ENV=development nodemon --legacy-watch src/worker.ts",
        "worker:dev:prod": "cross-env NODE_ENV=production nodemon --legacy-watch src/worker.ts",
        "worker:start": "cross-env NODE_ENV=production node dist/worker.js",
        "worker:start:dev": "cross-env NODE_ENV=development node dist/worker.js",
        "env:print": "cross-env DEBUG=dotenv-flow node -e \"require('dotenv-flow').config();console.log(JSON.stringify(process.env,null,2))\"",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format:check": "prettier --check .",
        "format:fix": "prettier --write .",
        "test": "cross-env NODE_ENV=test vitest run",
        "test:watch": "cross-env NODE_ENV=test vitest",
        "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
        "prepare": "husky",
        "prisma:generate": "node scripts/with-env.cjs prisma generate",
        "prisma:migrate:dev": "node scripts/with-env.cjs prisma migrate dev",
        "prisma:migrate:deploy": "node scripts/with-env.cjs prisma migrate deploy",
        "prisma:migrate:reset": "node scripts/with-env.cjs prisma migrate reset",
        "prisma:studio": "node scripts/with-env.cjs prisma studio",
        "prisma:seed": "cross-env NODE_ENV=development ts-node prisma/seed.ts"
    },
    "prisma": {
        "seed": "cross-env NODE_ENV=development ts-node prisma/seed.ts"
    },
    "keywords": [
        "lms",
        "education",
        "learnhub"
    ],
    "author": "LearnHub",
    "lint-staged": {
        "*.ts": [
            "npm run lint:fix",
            "npm run format:fix"
        ]
    },
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@emnapi/core": "1.10.0",
        "@emnapi/runtime": "1.10.0",
        "@eslint/js": "^9.32.0",
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/multer": "^1.4.12",
        "@types/node": "^24.1.0",
        "@types/nodemailer": "^6.4.17",
        "@types/source-map-support": "^0.5.10",
        "@types/supertest": "^6.0.2",
        "@types/swagger-ui-express": "^4.1.7",
        "@types/uuid": "^10.0.0",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint": "^9.32.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2",
        "nodemon": "^3.1.10",
        "prettier": "3.6.2",
        "prisma": "5.22.0",
        "supertest": "^7.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.38.0",
        "vitest": "^4.1.5"
    },
    "dependencies": {
        "@prisma/client": "5.22.0",
        "bcrypt": "^5.1.1",
        "bullmq": "^5.28.0",
        "colorette": "^2.0.20",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "cross-env": "^10.0.0",
        "dotenv-flow": "^4.1.0",
        "express": "^5.1.0",
        "google-auth-library": "^9.15.0",
        "helmet": "^8.1.0",
        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^8.0.7",
        "pino": "^9.5.0",
        "pino-http": "^10.3.0",
        "pino-pretty": "^11.3.0",
        "prom-client": "^15.1.3",
        "rate-limiter-flexible": "^7.2.0",
        "razorpay": "^2.9.5",
        "socket.io": "^4.8.1",
        "source-map-support": "^0.5.21",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^11.0.3",
        "winston": "^3.17.0",
        "zod": "^3.23.8"
    }
}
