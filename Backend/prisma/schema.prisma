// LearnHub LMS — Phase 1 Prisma schema
// Multi-tenant by design: tenant_id on every domain row.
// Soft-delete via deleted_at (enforced in Prisma middleware — see db.ts).
//
// KNOWN WARNING: VSCode's Prisma extension ships a Prisma 7 LSP that flags
// `url = env("DATABASE_URL")` below as "no longer supported". We intentionally
// stay on Prisma 5 for Phase 1 — Prisma 7 removed `$use` middleware which our
// soft-delete + tenant-scoping depends on (would require a Client Extensions
// rewrite). The warning is editor-only and does not affect generate, migrate,
// or runtime. To silence the editor warning, downgrade the Prisma VSCode
// extension to a 5.x-compatible build until we migrate.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime app traffic — typically the Neon pooler URL (the hostname has
  // "-pooler" in it). Prisma's query engine talks here.
  url      = env("DATABASE_URL")
  // DDL-only — migrations run through here so they bypass the pooler. Falls
  // back to DATABASE_URL when DIRECT_URL is unset (e.g. local Postgres in
  // Docker, where there is no pooler). For Neon, set this to the same URL
  // as DATABASE_URL with `-pooler` removed from the hostname.
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

// CLIENT was removed in Phase 2 (§5.1) — ADMIN is the canonical tenant owner role.
// Existing CLIENT users are migrated to ADMIN by the accompanying SQL migration.
enum Role {
  SUPER_ADMIN
  ADMIN
  TRAINER
  STUDENT
  COUNSELLING_MANAGER
  COUNSELLOR
  SUPPORT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum TenantPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum CoursePublishState {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  YOUTUBE
  EXTERNAL_LIVE // Zoom / Meet link in metadata (Phase 1 fallback)
  TEXT
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum EnrollmentStatus {
  PENDING_PAYMENT
  ACTIVE
  COMPLETED
  REFUNDED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  DUE
  PAID
  FAILED
  REFUNDED
}

enum PaymentGateway {
  RAZORPAY
  STRIPE
}

// How a student paid. ONLINE is the default Razorpay/Stripe flow. EMI tags
// invoices that are part of an installment plan; CASH is offline (counsellor
// collected at branch) — admin/superadmin must approve a counsellor's CASH
// or EMI request before the invoice flips to PAID.
enum PaymentMethod {
  ONLINE
  EMI
  CASH
}

enum PaymentRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PaymentEventStatus {
  CREATED
  VERIFIED
  FAILED
  REFUNDED
}

enum QuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

enum BatchStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum CounsellorInviteStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum StudentSignupStatus {
  CREATED
  CREDS_SHARED
  ENROLLED
}

enum EnquiryStage {
  NEW
  DEMO_SCHEDULED
  CONVERTED
  LOST
}

enum CounsellorTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum CounsellorTaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

// Outbound email status. Distinct from NotificationStatus so we can record
// soft-skips (no SMTP configured, recipient on the fake-domain block list,
// tenant has no contact email) without polluting the bell-icon stream.
enum EmailDeliveryStatus {
  SENT
  FAILED
  SKIPPED
}

// ---------- Core tables ----------

model Tenant {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  plan          TenantPlan   @default(FREE)
  status        TenantStatus @default(ACTIVE)
  brandingLogo  String?
  brandingColor String?      @default("#2563eb")
  settings      Json         @default("{}")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  users                 User[]
  invites               Invite[]
  courses               Course[]
  batches               Batch[]
  enrollments           Enrollment[]
  invoices              Invoice[]
  paymentEvents         PaymentEvent[]
  quizzes               Quiz[]
  quizAttempts          QuizAttempt[]
  counsellorInviteLinks CounsellorInviteLink[]
  studentSignups        StudentSignup[]
  counsellorTargets     CounsellorTarget[]
  counsellorTasks       CounsellorTask[]
  tickets               Ticket[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  enquiries             Enquiry[]
  newsletterSubscribers NewsletterSubscriber[]
  saasPayments          TenantPayment[]
  mediaAssets           MediaAsset[]
  collections           Collection[]
  assignments           Assignment[]
  assignmentSubmissions AssignmentSubmission[]
  paymentRequests       PaymentRequest[]
  emailLogs             EmailLog[]

  @@index([slug])
  @@map("tenants")
}

// One-time-use token issued after a public Razorpay checkout completes.
// The student receives a "set your new password" link in the welcome
// email — clicking it lands on /student/set-password?token=… in the
// Frontend, which calls /auth/password/reset with the token to flip the
// account's password and invalidate the row. Also reusable for forgot-
// password flows. Single-use: `usedAt` flips on first redemption and the
// row is rejected on every subsequent call.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  // Hashed (sha-256) so a leak of the row doesn't leak the URL.
  tokenHash String    @unique
  // Free-form purpose tag — `enrollment_welcome`, `forgot_password`, etc.
  // Lets us audit-log + analytics-segment redemptions later.
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Outbound email telemetry — one row per attempt regardless of outcome.
// Used by the admin "email troubleshooting" panel and the dev console to
// trace delivery failures. Distinct from Notification (which is the bell-
// inbox model the user sees) — every Notification with EMAIL channel
// produces one EmailLog, but transactional / system mails may write only
// here without a corresponding Notification row.
model EmailLog {
  id          String              @id @default(uuid())
  tenantId    String?
  userId      String? // recipient when known
  toEmail     String
  fromEmail   String
  replyTo     String?
  subject     String
  template    String?
  status      EmailDeliveryStatus
  errorReason String?
  messageId   String? // SMTP-returned message id when delivery succeeded
  createdAt   DateTime            @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([toEmail])
  @@map("email_logs")
}

// SaaS-billing records: each row is an invoice the platform issues to the
// tenant for their subscription. Distinct from Invoice (which is the tenant's
// own invoices to its students). §4.4 + §10.2.
model TenantPayment {
  id               String              @id @default(uuid())
  tenantId         String
  amount           Int // total in paise (smallest currency unit)
  currency         String              @default("INR")
  planLabel        String? // free-form label like "GROWTH · monthly"
  periodStart      DateTime?
  periodEnd        DateTime?
  description      String? // optional internal/customer-facing line item
  status           TenantPaymentStatus @default(PENDING)
  // Razorpay handshake — populated when a payment order is created.
  gateway          PaymentGateway?     @default(RAZORPAY)
  gatewayOrderId   String?
  gatewayPaymentId String?
  // Audit / authorship.
  createdById      String? // SA who issued the invoice
  paidAt           DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("tenant_payments")
}

enum TenantPaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

model User {
  id            String       @id @default(uuid())
  tenantId      String
  email         String
  phone         String?
  passwordHash  String?
  googleSub     String?
  provider      AuthProvider @default(LOCAL)
  role          Role
  firstName     String
  lastName      String
  avatarUrl     String?
  status        UserStatus   @default(PENDING)
  emailVerified Boolean      @default(false)
  tokenVersion  Int          @default(0) // bumps on password change → invalidates JWTs
  lastLoginAt   DateTime?
  managerId     String? // self-ref: counsellor → their COUNSELLING_MANAGER
  employeeCode  String? // optional internal id counsellors can quote to students
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  tenant                     Tenant                 @relation(fields: [tenantId], references: [id])
  refreshTokens              RefreshToken[]
  coursesTaught              Course[]               @relation("CourseTrainer")
  enrollments                Enrollment[]
  quizAttempts               QuizAttempt[]
  invoices                   Invoice[]
  ticketsOpened              Ticket[]               @relation("TicketOpener")
  ticketsAssigned            Ticket[]               @relation("TicketAssignee")
  ticketComments             TicketComment[]
  notifications              Notification[]
  auditLogs                  AuditLog[]
  batchesLed                 Batch[]                @relation("BatchTrainer")
  counsellorInviteLinks      CounsellorInviteLink[] @relation("CounsellorInviteCreator")
  studentSignupsAsCounsellor StudentSignup[]        @relation("StudentSignupCounsellor")
  studentSignup              StudentSignup?         @relation("StudentSignupUser")
  counsellorTargets          CounsellorTarget[]     @relation("CounsellorTargetOwner")
  manager                    User?                  @relation("CounsellorManagement", fields: [managerId], references: [id])
  directReports              User[]                 @relation("CounsellorManagement")
  tasksAssigned              CounsellorTask[]       @relation("CounsellorTaskAssignee")
  tasksCreated               CounsellorTask[]       @relation("CounsellorTaskCreator")
  enquiriesAssigned          Enquiry[]              @relation("EnquiryCounsellor")
  mediaUploads               MediaAsset[]           @relation("MediaUploader")
  assignmentsLed             Assignment[]           @relation("AssignmentTrainer")
  assignmentSubmissions      AssignmentSubmission[] @relation("AssignmentSubmissionUser")
  assignmentsGraded          AssignmentSubmission[] @relation("AssignmentSubmissionGrader")
  paymentRequestsRequested   PaymentRequest[]       @relation("PaymentRequestRequester")
  paymentRequestsForMe       PaymentRequest[]       @relation("PaymentRequestStudent")
  paymentRequestsReviewed    PaymentRequest[]       @relation("PaymentRequestReviewer")
  passwordResetTokens        PasswordResetToken[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@index([tenantId, managerId])
  @@index([googleSub])
  @@map("users")
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  tenantId     String
  tokenHash    String    @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Invite {
  id          String       @id @default(uuid())
  tenantId    String
  email       String
  role        Role
  tokenHash   String       @unique
  status      InviteStatus @default(PENDING)
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, email])
  @@map("invites")
}

// ---------- Courses & Lessons ----------

model Course {
  id                   String             @id @default(uuid())
  tenantId             String
  title                String
  // Short marketing tag-line shown under the title on the catalog card and
  // detail hero. Distinct from `description`, which is the long-form body.
  subtitle             String?
  slug                 String
  description          String?
  // Catalog thumbnail (16:9 card image). `heroUrl` is a separate, larger
  // banner shown on the course detail page; tenants can either reuse the
  // thumbnail or upload a wider crop here.
  thumbnailUrl         String?
  heroUrl              String?
  price                Int                @default(0) // smallest currency unit (paise)
  currency             String             @default("INR")
  gstPercent           Int                @default(18)
  trainerId            String?
  publishState         CoursePublishState @default(DRAFT)
  tags                 String[]           @default([])
  // Skill-level + delivery language. `language` is an ISO-639-1 code
  // (e.g. 'en', 'hi'); we keep it free-form so tenants can pick anything.
  level                CourseLevel        @default(ALL_LEVELS)
  language             String             @default("en")
  // Long-form arrays — what students will learn, what they need before
  // joining, who the course is built for. Each entry is one bullet point.
  outcomes             String[]           @default([])
  prerequisites        String[]           @default([])
  audience             String[]           @default([])
  // Enrolment window. `enrolmentCap` 0/null means unlimited; dates are
  // optional and only enforced by the public site (the Razorpay flow
  // refuses checkouts outside the window).
  enrolmentCap         Int?
  startsAt             DateTime?
  endsAt               DateTime?
  // Issue a verifiable certificate when a student hits 100% progress.
  // `certificateTemplate` is a free-form key (e.g. 'default') reserved
  // for a future template registry; for now the platform default ships
  // for every course where the toggle is on.
  certificateEnabled   Boolean            @default(false)
  certificateTemplate  String?
  // Pricing tiers — array of { key, label, priceMinor, emiMinor?, recommended?, features?[] }.
  // Empty array means the legacy single-price flow applies (charge `price`).
  // Used by the public checkout: when the frontend passes a `tierKey`, the
  // backend looks up the tier here and charges that price (overriding `price`).
  // Stored as JSON so admins can grow the schema without a per-field migration.
  priceTiers           Json               @default("[]")
  // Default registration / reservation fee in paise charged when the user
  // picks "Reserve seat" instead of paying full. Falls back to the tenant
  // default (tenant.settings.payments.registrationFeeMinor → ₹5,000).
  registrationFeeMinor Int?
  curriculumJson       Json               @default("{}") // section → lesson tree
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  trainer               User?                  @relation("CourseTrainer", fields: [trainerId], references: [id])
  sections              CourseSection[]
  enrollments           Enrollment[]
  quizzes               Quiz[]
  batches               Batch[]
  counsellorInviteLinks CounsellorInviteLink[]
  assignments           Assignment[]

  @@unique([tenantId, slug])
  @@index([tenantId, publishState])
  @@map("courses")
}

model CourseSection {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("course_sections")
}

model Lesson {
  id          String     @id @default(uuid())
  sectionId   String
  title       String
  description String?
  type        LessonType @default(YOUTUBE)
  youtubeId   String?
  externalUrl String?
  durationSec Int        @default(0)
  order       Int        @default(0)
  // Free-preview lessons render outside the paywall on the public course
  // detail page — useful for letting prospects sample one or two videos
  // before paying. Defaults to false; admins flip it from the lesson editor.
  freePreview Boolean    @default(false)
  // Attached resources: array of `{ url: string, label?: string, type?: 'pdf' | 'link' | 'file' }`.
  // Stored as JSON so we don't need a Resource table for what's effectively
  // a tiny enrichment of the lesson.
  resources   Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  section  CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([sectionId])
  @@map("lessons")
}

model LessonProgress {
  id           String    @id @default(uuid())
  lessonId     String
  enrollmentId String
  watchedSec   Int       @default(0)
  completed    Boolean   @default(false)
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt

  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, enrollmentId])
  @@map("lesson_progress")
}

// ---------- Batches ----------

model Batch {
  id        String      @id @default(uuid())
  tenantId  String
  courseId  String
  name      String
  code      String
  trainerId String?
  startDate DateTime
  endDate   DateTime?
  capacity  Int         @default(50)
  status    BatchStatus @default(UPCOMING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  course      Course       @relation(fields: [courseId], references: [id])
  trainer     User?        @relation("BatchTrainer", fields: [trainerId], references: [id])
  enrollments Enrollment[]

  @@unique([tenantId, code])
  @@index([tenantId, courseId])
  @@map("batches")
}

// ---------- Enrollment & Payment ----------

model Enrollment {
  id           String           @id @default(uuid())
  tenantId     String
  userId       String
  courseId     String
  batchId      String?
  counsellorId String? // tracks attribution for counsellor target rollups
  status       EnrollmentStatus @default(PENDING_PAYMENT)
  progressPct  Int              @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
  course         Course           @relation(fields: [courseId], references: [id])
  batch          Batch?           @relation(fields: [batchId], references: [id])
  invoices       Invoice[]
  lessonProgress LessonProgress[]

  @@unique([tenantId, userId, courseId])
  @@index([tenantId, status])
  @@index([tenantId, counsellorId])
  @@map("enrollments")
}

model Invoice {
  id               String         @id @default(uuid())
  tenantId         String
  userId           String
  enrollmentId     String?
  number           String // tenant-scoped human-readable invoice number
  amount           Int // smallest unit
  currency         String         @default("INR")
  gstPercent       Int            @default(18)
  gstAmount        Int            @default(0)
  totalAmount      Int
  gateway          PaymentGateway @default(RAZORPAY)
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewayRef       String? // legacy ref
  // How the student paid. ONLINE invoices flow through Razorpay; EMI/CASH
  // are admin-approved offline payments captured by counsellors.
  paymentMethod    PaymentMethod  @default(ONLINE)
  // Free-form note ("Cash collected at branch", "EMI 3 of 6") — surfaced to
  // counsellor + admin in the invoice list. Optional.
  paymentNote      String?
  pdfUrl           String?
  status           InvoiceStatus  @default(DRAFT)
  dueAt            DateTime?
  paidAt           DateTime?
  refundedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  enrollment      Enrollment?      @relation(fields: [enrollmentId], references: [id])
  paymentEvents   PaymentEvent[]
  paymentRequests PaymentRequest[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@map("invoices")
}

// Counsellor-initiated request to record an offline (CASH) or installment
// (EMI) payment against a student. The request lives in PENDING until an
// ADMIN or SUPER_ADMIN approves or rejects it; on approval the linked
// Invoice flips to PAID with paymentMethod set, and the counsellor gets a
// notification. Tenants with no offline collection just never use this
// model — it's additive and doesn't affect the public Razorpay flow.
model PaymentRequest {
  id              String               @id @default(uuid())
  tenantId        String
  invoiceId       String? // null when the counsellor is requesting a brand-new payment (course + amount provided inline)
  // The counsellor making the request + the student the payment is for.
  requestedById   String
  studentId       String
  // What the counsellor is asking for.
  method          PaymentMethod
  amountMinor     Int
  currency        String               @default("INR")
  note            String?
  // Optional EMI breakdown — total installments + which one this represents.
  // Both null for non-EMI methods.
  emiTotal        Int?
  emiSequence     Int?
  status          PaymentRequestStatus @default(PENDING)
  // Resolution audit. reviewerId + reviewedAt are populated once approved
  // or rejected; rejectionReason holds the explanation when applicable.
  reviewerId      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  requestedBy User     @relation("PaymentRequestRequester", fields: [requestedById], references: [id])
  student     User     @relation("PaymentRequestStudent", fields: [studentId], references: [id])
  reviewer    User?    @relation("PaymentRequestReviewer", fields: [reviewerId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, requestedById])
  @@index([tenantId, studentId])
  @@map("payment_requests")
}

model PaymentEvent {
  id               String             @id @default(uuid())
  tenantId         String
  invoiceId        String?
  gateway          PaymentGateway
  gatewayEventId   String             @unique // idempotency key from webhook
  gatewayOrderId   String?
  gatewayPaymentId String?
  status           PaymentEventStatus
  amount           Int?
  rawPayload       Json
  signatureValid   Boolean            @default(false)
  createdAt        DateTime           @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, invoiceId])
  @@map("payment_events")
}

// ---------- Quizzes ----------

model Quiz {
  id          String    @id @default(uuid())
  tenantId    String
  courseId    String
  title       String
  description String?
  durationSec Int       @default(600)
  maxAttempts Int       @default(3)
  passPercent Int       @default(60)
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  course    Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([tenantId, courseId])
  @@map("quizzes")
}

model QuizQuestion {
  id         String   @id @default(uuid())
  quizId     String
  prompt     String
  options    Json // array of { id, text }
  correctIds String[] // ids of correct option(s); 1 for MCQ, multi for MCQ-multi
  marks      Int      @default(1)
  order      Int      @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id          String            @id @default(uuid())
  tenantId    String
  quizId      String
  userId      String
  answers     Json              @default("[]") // [{ questionId, selectedIds }]
  score       Int               @default(0)
  maxScore    Int               @default(0)
  percent     Int               @default(0)
  passed      Boolean           @default(false)
  status      QuizAttemptStatus @default(IN_PROGRESS)
  startedAt   DateTime          @default(now())
  submittedAt DateTime?
  expiresAt   DateTime

  tenant Tenant @relation(fields: [tenantId], references: [id])
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, quizId, userId])
  @@map("quiz_attempts")
}

// ---------- Assignments ----------
//
// Free-form take-home work, distinct from Quizzes. A student submits text +
// optional file URL; the trainer (or admin) grades it later. Unlike quizzes,
// there's no auto-grading and no time limit.

enum AssignmentSubmissionStatus {
  DRAFT // student saved progress but didn't submit
  SUBMITTED // sealed by the student, awaiting grading
  GRADED // staff marked + scored
  RETURNED // staff sent it back for rework (student can re-submit)
}

model Assignment {
  id           String    @id @default(uuid())
  tenantId     String
  courseId     String
  trainerId    String?
  title        String
  description  String?
  instructions String? // markdown body shown to the student
  dueAt        DateTime?
  maxScore     Int       @default(100)
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  course      Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  trainer     User?                  @relation("AssignmentTrainer", fields: [trainerId], references: [id])
  submissions AssignmentSubmission[]

  @@index([tenantId, courseId])
  @@index([tenantId, isPublished])
  @@map("assignments")
}

model AssignmentSubmission {
  id           String                     @id @default(uuid())
  tenantId     String
  assignmentId String
  userId       String
  textAnswer   String? // free-form student response
  fileUrl      String? // optional uploaded artefact (PDF, zip, link)
  status       AssignmentSubmissionStatus @default(DRAFT)
  score        Int? // null until graded
  feedback     String? // grader's note to the student
  gradedById   String?
  submittedAt  DateTime?
  gradedAt     DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation("AssignmentSubmissionUser", fields: [userId], references: [id])
  gradedBy   User?      @relation("AssignmentSubmissionGrader", fields: [gradedById], references: [id])

  @@unique([assignmentId, userId])
  @@index([tenantId, assignmentId])
  @@index([tenantId, userId])
  @@map("assignment_submissions")
}

// ---------- Counsellor onboarding (replaces lead pipeline) ----------

model CounsellorInviteLink {
  id           String                 @id @default(uuid())
  tenantId     String
  counsellorId String
  token        String                 @unique // raw token used in public URL
  label        String? // counsellor's note: "Bangalore drive – Apr"
  courseId     String? // optional default enrolment after signup
  maxUses      Int                    @default(1)
  usesCount    Int                    @default(0)
  status       CounsellorInviteStatus @default(ACTIVE)
  expiresAt    DateTime
  lastUsedAt   DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deletedAt    DateTime?

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  counsellor User            @relation("CounsellorInviteCreator", fields: [counsellorId], references: [id])
  course     Course?         @relation(fields: [courseId], references: [id])
  signups    StudentSignup[]

  @@index([tenantId, counsellorId])
  @@index([token])
  @@map("counsellor_invite_links")
}

model StudentSignup {
  id              String              @id @default(uuid())
  tenantId        String
  inviteLinkId    String
  counsellorId    String
  userId          String?             @unique
  firstName       String
  lastName        String
  email           String
  phone           String?
  dateOfBirth     DateTime?
  city            String?
  state           String?
  address         String?
  qualification   String?
  interest        String?
  notes           String?
  // Free-form structured details (education, professional, gap, etc.). Stored
  // as JSON so the onboarding form can grow without a migration per field.
  // Schema is enforced at the API layer via Zod in counsellor-invite.schema.ts.
  extra           Json?
  // One-time plaintext password generated on submit. Cleared after first login
  // so it can be re-shown to the counsellor exactly once via the share endpoint.
  initialPassword String?
  status          StudentSignupStatus @default(CREATED)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  inviteLink CounsellorInviteLink @relation(fields: [inviteLinkId], references: [id])
  counsellor User                 @relation("StudentSignupCounsellor", fields: [counsellorId], references: [id])
  user       User?                @relation("StudentSignupUser", fields: [userId], references: [id])

  @@index([tenantId, counsellorId])
  @@map("student_signups")
}

model CounsellorTask {
  id          String                 @id @default(uuid())
  tenantId    String
  assigneeId  String // counsellor this is for
  createdById String // manager / admin who created it
  title       String
  description String?
  status      CounsellorTaskStatus   @default(OPEN)
  priority    CounsellorTaskPriority @default(NORMAL)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  deletedAt   DateTime?

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  assignee  User   @relation("CounsellorTaskAssignee", fields: [assigneeId], references: [id])
  createdBy User   @relation("CounsellorTaskCreator", fields: [createdById], references: [id])

  @@index([tenantId, assigneeId, status])
  @@index([tenantId, createdById])
  @@map("counsellor_tasks")
}

model CounsellorTarget {
  id               String   @id @default(uuid())
  tenantId         String
  counsellorId     String
  periodStart      DateTime // first day of the month, midnight UTC
  periodEnd        DateTime // last second of the month
  targetSignups    Int      @default(0)
  targetEnrolments Int      @default(0)
  targetRevenue    Int      @default(0) // smallest currency unit
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  counsellor User   @relation("CounsellorTargetOwner", fields: [counsellorId], references: [id])

  @@unique([tenantId, counsellorId, periodStart])
  @@map("counsellor_targets")
}

// ---------- Support tickets ----------

model Ticket {
  id          String         @id @default(uuid())
  tenantId    String
  number      String // tenant-scoped human ref
  openerId    String
  assigneeId  String?
  subject     String
  description String
  priority    TicketPriority @default(NORMAL)
  status      TicketStatus   @default(OPEN)
  slaDueAt    DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  opener   User            @relation("TicketOpener", fields: [openerId], references: [id])
  assignee User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  comments TicketComment[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@map("tickets")
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  body      String
  internal  Boolean  @default(false) // internal notes vs customer-facing
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@map("ticket_comments")
}

// ---------- Notifications ----------

model Notification {
  id        String              @id @default(uuid())
  tenantId  String
  userId    String
  channel   NotificationChannel @default(IN_APP)
  template  String
  subject   String?
  body      String
  data      Json                @default("{}")
  status    NotificationStatus  @default(PENDING)
  readAt    DateTime?
  sentAt    DateTime?
  error     String?
  createdAt DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, status])
  @@map("notifications")
}

// ---------- Enquiries (public website leads) ----------
// A student fills the public enquiry form → we drop a row here and auto-assign
// to the next available counsellor via least-loaded round-robin. No user
// account is created at this stage; that happens after the counsellor converts.

model Enquiry {
  id            String       @id @default(uuid())
  tenantId      String
  name          String
  email         String
  phone         String
  course        String
  language      String?
  city          String?
  address       String?
  qualification String?
  message       String?
  source        String       @default("website")
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  // Structured education / professional / gap details — same shape the
  // onboarding form uses. JSON so adding new sections doesn't need a migration.
  extra         Json?
  stage         EnquiryStage @default(NEW)
  assignedToId  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  assignedTo User?  @relation("EnquiryCounsellor", fields: [assignedToId], references: [id])

  @@index([tenantId, stage, createdAt])
  @@index([tenantId, assignedToId, stage])
  @@map("enquiries")
}

// Newsletter subscribers — captured by the public marketing site (5173) and
// surfaced to ADMIN/SA in a per-tenant list. Email is unique per tenant so
// repeat sign-ups update status rather than creating duplicates.
model NewsletterSubscriber {
  id          String   @id @default(uuid())
  tenantId    String
  email       String
  name        String?
  // Where on the site they signed up — 'blog-sidebar', 'footer', etc.
  source      String   @default("website")
  status      String   @default("active") // active | unsubscribed
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId, createdAt])
  @@map("newsletter_subscribers")
}

// ---------- CMS / dynamic collections (per-tenant) ----------
//
// Generic per-tenant content collections (Blog, Press, Events). Each tenant
// defines its own `fields` schema; items store `data` as JSON validated
// against that schema at the API boundary. Lets non-engineers spin up new
// content types without a migration.

model Collection {
  id          String   @id @default(uuid())
  tenantId    String
  name        String // human label, e.g. "Blog posts"
  slug        String // URL-safe, unique per tenant: "blog"
  description String?
  // Field definitions — each entry: { key, label, type, required?, options?[] }
  // Types: 'text' | 'longtext' | 'richtext' | 'number' | 'boolean' | 'date' | 'image' | 'select'
  fields      Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  items  CollectionItem[]

  @@unique([tenantId, slug])
  @@map("collections")
}

model CollectionItem {
  id           String    @id @default(uuid())
  tenantId     String
  collectionId String
  slug         String
  data         Json      @default("{}")
  published    Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, slug])
  @@index([tenantId, collectionId, published])
  @@map("collection_items")
}

// ---------- Media library (per-tenant) ----------
//
// Tracks every media upload so the website editor's image picker can list
// what's available without scanning disk. Per-tenant — uploads belong to the
// tenant whose user uploaded them. The actual file lives in `public/uploads`
// (or whichever storage backend the upload middleware writes to); `url` is
// the canonical public path.

model MediaAsset {
  id           String   @id @default(uuid())
  tenantId     String
  uploadedById String?
  filename     String
  originalName String
  mimetype     String
  sizeBytes    Int
  url          String
  // Free-form bucket so editors can group ("hero", "blog", etc.). The upload
  // route's `kind` param sets this by default.
  kind         String   @default("media")
  altText      String?
  createdAt    DateTime @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  uploadedBy User?  @relation("MediaUploader", fields: [uploadedById], references: [id])

  @@index([tenantId, createdAt])
  @@map("media_assets")
}

// ---------- Audit log (cross-tenant traceable) ----------

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  userId     String?
  action     String // e.g. auth.login, course.publish, lead.move
  entityType String?
  entityId   String?
  metadata   Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}
