# =============================================================================
# .env.example  —  canonical template. Copy this to create secret override files.
# =============================================================================
# This project uses dotenv-flow. Files load in this order (later wins):
#
#     .env                      (gitignored — rarely used)
#     .env.local                (gitignored — personal overrides across envs)
#     .env.<NODE_ENV>           (committed — .env.development / .env.production)
#     .env.<NODE_ENV>.local     (gitignored — real secrets per env)
#
# Typical usage:
#   - For dev, .env.development is already committed with sane localhost defaults.
#     Copy this file only if you want to override a secret locally:
#
#         cp .env.example .env.development.local
#
#   - For running with the production profile locally (smoke test):
#
#         cp .env.example .env.production.local
#
#   - In deployed environments, secrets come from the platform (Render env /
#     AWS Secrets Manager / GitHub Environment), not from files.
#
# NEVER put real production secrets in this file. It is committed.
# =============================================================================


# ---- Runtime ----------------------------------------------------------------
# ENV mirrors NODE_ENV for our code's EApplicationEnvironment switch.
ENV=development
PORT=3000
SERVER_URL=http://localhost:3000

# CSV of allowed CORS origins for multi-tenant frontends.
CORS_ORIGIN=http://localhost:5173
ALLOWED_TENANT_ORIGINS=http://localhost:5173,http://localhost:8080


# ---- PostgreSQL (Neon or local docker) --------------------------------------
# Local docker:  postgresql://learnhub:learnhub@localhost:5432/learnhub?schema=public
# Neon:          postgresql://user:pass@ep-xxx.neon.tech/learnhub?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/learnhub?schema=public"


# ---- Redis (Upstash or local docker) ---------------------------------------
# Local:   redis://localhost:6379
# Upstash: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379


# ---- JWT --------------------------------------------------------------------
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000


# ---- Cookies ----------------------------------------------------------------
# Local dev: leave COOKIE_DOMAIN empty and COOKIE_SECURE=false.
# Prod:      COOKIE_DOMAIN=.yourdomain.com, COOKIE_SECURE=true (HTTPS only).
COOKIE_DOMAIN=
COOKIE_SECURE=false


# ---- Google OAuth -----------------------------------------------------------
# Leave blank to disable Google sign-in. Email/password still works.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
GOOGLE_POST_LOGIN_REDIRECT=http://localhost:5173/auth/callback


# ---- Nodemailer (email) -----------------------------------------------------
# Blank NODEMAILER_MAIL/PASS → the notification worker logs emails instead of
# sending them (perfect for offline dev).
#
# Default transport is Gmail with an App Password (https://myaccount.google.com/apppasswords).
# To use generic SMTP instead, set NODEMAILER_HOST/PORT/SECURE.
NODEMAILER_MAIL=
NODEMAILER_PASS=
NODEMAILER_HOST=
NODEMAILER_PORT=587
NODEMAILER_SECURE=false
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Albero Academy


# ---- Razorpay (payments) ----------------------------------------------------
# TEST-mode keys in dev; LIVE keys only in prod. WEBHOOK_SECRET must match the
# one configured in the Razorpay Dashboard webhook settings.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=


# ---- Google Sheets (lead push, §9.2) ----------------------------------------
# Platform-wide service account. Each tenant pastes its own Sheet ID in the
# Admin → Integrations page and adds GOOGLE_SHEETS_CLIENT_EMAIL as Editor on
# their sheet. Leave both blank to disable Sheets push.
#   1. Create a GCP project → enable Sheets API → create a Service Account.
#   2. Generate a JSON key. Copy `client_email` here.
#   3. Copy the `private_key` value here, escaping newlines as \n.
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=


# ---- Security ---------------------------------------------------------------
# Prod: 12. Dev/test: 4 for faster bcrypt.
BCRYPT_ROUNDS=12


# ---- Observability ----------------------------------------------------------
# LOG_LEVEL is one of: trace | debug | info | warn | error
LOG_LEVEL=info
# Optional — if set, errors are reported to Sentry.
SENTRY_DSN=


# =============================================================================
# Quick-start recipes — which file to put which values in
# =============================================================================
#
# Local development (the common case):
#   Nothing to do — .env.development is already committed with localhost
#   defaults. Start with:     npm run dev
#
# Point local dev at Neon instead of Docker Postgres:
#   Create .env.development.local  containing just:
#       DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/..."
#
# Run the production profile locally (smoke test against local DB):
#   Create .env.production.local   containing:
#       DATABASE_URL=postgresql://learnhub:learnhub@localhost:5432/learnhub
#       REDIS_URL=redis://localhost:6379
#       JWT_ACCESS_SECRET=<generated>
#       JWT_REFRESH_SECRET=<generated>
#       SERVER_URL=http://localhost:3000
#       CORS_ORIGIN=http://localhost:5173
#       COOKIE_SECURE=false
#   Then:                     npm run dev:prod          (hot reload, prod env)
#   or:                       npm run build && npm start  (compiled, prod env)
#
# CI / production deploy:
#   Set every secret in the platform's env-var UI. .env.production supplies
#   the non-secret defaults (log level, cookie domain, redirect URIs).
# =============================================================================
