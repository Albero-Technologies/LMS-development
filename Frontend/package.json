{
    "name": "learnhub-frontend",
    "private": true,
    "version": "1.0.0",
    "description": "LearnHub LMS Phase 1 frontend — React + Vite + TanStack + PWA",
    "type": "module",
    "scripts": {
        "prepare": "husky",
        "lint:eslint": "eslint",
        "lint:fix": "eslint --fix",
        "format:check": "prettier --check .",
        "format:fix": "prettier --write .",
        "lint:stylelint": "stylelint src/**/*.css",
        "lint:stylelint:fix": "stylelint src/**/*.css --fix",
        "dev": "vite --mode development",
        "start": "vite --mode production",
        "test": "vitest --mode test",
        "test:coverage": "vitest run --coverage --mode test",
        "typecheck": "tsc -b --noEmit",
        "build": "tsc -b && vite build --mode production",
        "preview": "vite preview --mode production"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{css,md,json}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hookform/resolvers": "^3.9.1",
        "@sentry/react": "^10.0.0",
        "@tanstack/react-query": "^5.62.2",
        "@tanstack/react-query-devtools": "^5.62.2",
        "axios": "^1.7.9",
        "clsx": "^2.1.1",
        "framer-motion": "^12.0.0",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "lucide-react": "^0.469.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-hook-form": "^7.54.2",
        "react-router-dom": "^7.0.2",
        "socket.io-client": "^4.8.1",
        "sonner": "^1.7.1",
        "tailwind-merge": "^2.5.5",
        "tailwindcss": "^4.1.11",
        "zod": "^3.24.1",
        "zustand": "^5.0.2"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/js": "^9.30.1",
        "@sentry/vite-plugin": "^4.0.2",
        "@tailwindcss/vite": "^4.1.11",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.6.4",
        "@testing-library/react": "^16.3.0",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react": "^4.6.0",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9.30.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.3.0",
        "husky": "^9.1.7",
        "jsdom": "^26.1.0",
        "lint-staged": "^16.1.2",
        "prettier": "^3.6.2",
        "stylelint": "^16.23.0",
        "stylelint-config-standard": "^39.0.0",
        "stylelint-config-tailwindcss": "^1.0.0",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.35.1",
        "vite": "^7.0.4",
        "vite-plugin-pwa": "^1.0.0",
        "vitest": "^3.2.4",
        "workbox-window": "^7.3.0"
    }
}
