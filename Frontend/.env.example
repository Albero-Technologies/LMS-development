# Vite build-time — required
PORT=5174
BACKEND_PROXY=http://localhost:3000
VITE_ENV=development
# Albero marketing site root — used by deep-links from the dashboard back
# to the public Razorpay checkout (e.g. DEMO balance "Pay balance" button).
VITE_PUBLIC_SITE_URL=http://localhost:5173

# Optional — leave blank in dev, required in production builds only if you want
# Sentry release uploads or client-side error tracking.
SENTRY_TOKEN=
VITE_SENTRY_DSN=
